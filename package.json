{
  "name": "lunar",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "typecheck": "tsc --noEmit --pretty false",
    "build": "tsc --noEmit --pretty false && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "verify:build": "node scripts/verify-build.mjs",
    "qa": "npm run typecheck && npm run build && npm run verify:build",
    "qa:browser": "node scripts/browser-qa.mjs",
    "start": "vite --host 0.0.0.0 --port 5173"
  },
  "dependencies": {
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "6.0.3",
    "vite": "8.1.3"
  }
}
